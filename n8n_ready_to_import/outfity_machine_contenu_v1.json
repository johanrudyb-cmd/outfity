                            "name": "x-n8n-secret",
                            "value": "bmad_n8n_secret_2024_ultra_secure"
                        }
                    ]
                },
                "options": {}
            },
            "id": "a1b2c3d4-0002-0002-0002-000000000002",
            "name": "Fetch OUTFITY Articles",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
